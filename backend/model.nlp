oun daleb vacance"],["fr","les demandes de conges"],["fr","kifech nbadel l wa9t"],["fr","gerer l emploi du temps"],["fr","kifech nzid shift"],["fr","affecter les horaires"],["fr","badel planning"],["fr","changement de shift"],["fr","win nriguel l wa9t"],["fr","kifech nzid employe"],["fr","ajouter un membre"],["fr","nheb nzid tbib"],["fr","gerer le personnel"],["fr","nouveau compte"],["fr","kifech nfasakh employe"],["fr","modifier salaire mtaa خدام"],["fr","zid khadem jdid"],["fr","creer compte"],["fr","win nchouf chkoun pointa"],["fr","chkoun retard"],["fr","les presences du jour"],["fr","suivi de pointage"],["fr","chkoun absent"],["fr","retard mtaa l خدامة"],["fr","chouf chkoun hather"],["fr","les pointages"]]},"ner":{"settings":{"tag":"ner","entityPreffix":"%","entitySuffix":"%"},"rules":{}},"nlgManager":{"settings":{"tag":"nlg-manager"},"responses":{"fr":{"greetings":[{"answer":"👋 Bonjour ! Comment puis-je vous aider avec l'application Clinique RH aujourd'hui ?"}],"personnel.conge":[{"answer":"📅 **Vos congés :**\nPour demander un congé, allez dans l'onglet **Mes Congés**, puis cliquez sur le bouton 'Nouvelle demande'. Vous pourrez ensuite suivre son état (Approuvé, Refusé, En attente) dans cette même page."}],"personnel.planning":[{"answer":"🕒 **Votre emploi du temps :**\nVotre planning de la semaine est disponible dans la section **Mon Emploi du Temps**. Vous y verrez vos horaires exacts (Matin, Après-midi, Garde). Vous pouvez aussi y demander une modification si besoin."}],"personnel.pointage":[{"answer":"📍 **Comment pointer :**\nVous pouvez faire votre pointage (Check-In pour l'entrée / Check-Out pour la sortie) directement depuis votre **Tableau de Bord**. N'oubliez pas d'autoriser la géolocalisation sur votre navigateur et d'être dans la zone de la clinique !"}],"personnel.salaire":[{"answer":"💰 **Fiche de paie :**\nVotre fiche de paie détaillée avec vos heures supplémentaires et déductions est disponible sur votre **Tableau de Bord**. Dans la case 'Salaire', cliquez sur le lien souligné pour ouvrir et imprimer votre fiche du mois."}],"admin.conge":[{"answer":"📅 **Gestion des congés :**\nVous pouvez gérer toutes les demandes dans l'onglet **Gestion des congés**. Vous pourrez voir qui a demandé un congé, les dates, et vous pourrez **Approuver** ou **Refuser** les demandes en attente."}],"admin.planning":[{"answer":"🕒 **Gestion des emplois du temps :**\nAllez dans l'onglet **Emplois du temps**. Vous pouvez y attribuer des shifts (Matin, Après-midi, Nuit, Garde) pour chaque membre de l'équipe et gérer les demandes de modifications (remplacements)."}],"admin.personnel":[{"answer":"👥 **Gestion du personnel :**\nVous pouvez ajouter un nouvel employé, modifier ses informations (grade, service, salaire) ou supprimer un compte depuis l'onglet **Gestion du personnel**."}],"admin.pointage":[{"answer":"📍 **Suivi des pointages :**\nSur votre **Tableau de bord principal**, vous avez une vue globale et instantanée sur les présences du jour, les retards (avec le nombre de minutes exact) et les absences du personnel."}]}}},"actionManager":{"settings":{"tag":"action-manager"},"actions":{}},"slotManager":{}}